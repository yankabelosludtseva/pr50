<Page x:Class="pr50_2.Pages.Login"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:pr50_2.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Login">

    <Grid Background="White">
        <StackPanel Width="200" Height="135">
            <Label Content="Логин:" Height="25"/>
            <TextBox x:Name="tbLogin" Height="25"/>
            <Label Content="Пароль:" Height="25"/>
            <PasswordBox x:Name="tbPassword" Height="25"/>
            <Button Click="BtnAuth" Content="Войти" Height="25" Width="100" Margin="0, 10, 0, 0" HorizontalAlignment="Right"/>
        </StackPanel>
    </Grid>
</Page>
